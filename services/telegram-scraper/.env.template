# Copy to .env and fill in values
# Telegram API credentials — get from https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
TG_PHONE=+62xxx        # your phone number with country code
TG_PASSWORD=           # 2FA password if enabled, leave blank if not

# Optional: OTP delivery via bot (for non-interactive login)
# TG_BOT_TOKEN=
# TG_BOT_CHAT_ID=

# Backend — points to local fund-manager (do not change unless port changes)
TG_INSIGHT_API_URL=http://127.0.0.1:8787/feed/telegram/insight

# Debug
TG_DRY_RUN=false
TG_PRINT_MESSAGES=false
