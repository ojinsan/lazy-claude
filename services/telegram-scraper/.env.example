# Telegram API credentials (from https://my.telegram.org)
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here
TG_PHONE=+628123456789

# Optional: 2FA password
TG_PASSWORD=

# Session file name (stored in telegram/ directory)
TG_SESSION_NAME=telegram_session

# Optional: OTP via Telegram bot
TG_BOT_TOKEN=
TG_BOT_CHAT_ID=

# Scraping settings
TG_LOOKBACK_MINUTES=30
TG_MAX_REPLY_DEPTH=5
TG_POLL_INTERVAL_MINUTES=30

# Backend API
TG_INSIGHT_API_URL=http://localhost:8080/feed/telegram/insight
TG_UPLOAD_URL=http://localhost:8080/upload
TG_API_TIMEOUT=30

# Backfill settings
TG_BACKFILL_BATCH_SIZE=5

# Debug options (set to true to enable)
TG_DRY_RUN=false
TG_PRINT_MESSAGES=false
