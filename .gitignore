# Claude Code internals — do not commit
.credentials.json
file-history/
projects/
sessions/
session-env/
backups/
cache/
shell-snapshots/
paste-cache/
downloads/
telemetry/
history.jsonl
# Local-only settings (may contain sensitive allow rules)
settings.local.json

# Hook runtime log
hooks/tool-log.txt

# Memory (personal, managed separately)
memory/

# Local env (credentials)
.env.local
.env.*.local

# Runtime data (logs, tokens, monitoring state)
runtime/

# Python venvs
.venv-*/

# Python bytecode
tools/mcp-server/.venv/
tools/**/__pycache__/
tools/**/*.pyc
tools/**/*.pyo
tools/**/*.backup

# Playwright runtime artifacts
tools/general/playwright/car_comparison_rows.json
tools/general/playwright/.firefox-profile-threads/
tools/general/playwright/.pw-firefox-*/

# Vault — machine-generated transient data (Boss O's IP in daily/thesis/themes/lessons/journal stays tracked)
vault/data/*.json
vault/layer-output/**/*.md
vault/reviews/**/*.md
vault/.obsidian/
vault/*.canvas

# Services — runtime artifacts
services/**/.venv/
services/**/__pycache__/
